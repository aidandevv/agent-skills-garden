#!/usr/bin/env bash
# scripts/journal-init
# Initializes ./docs/dev_journal.md and ./docs/product_insights.md
# in the current git repo (or current directory if not in a repo).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT"
mkdir -p docs

if [ ! -f docs/dev_journal.md ]; then
  cat > docs/dev_journal.md << 'EOF'
# Engineering Development Journal
> Chronological log of architecture decisions, implementation pivots,
> constraint discoveries, verification results, and engineering milestones.

---
EOF
  echo "✓ docs/dev_journal.md"
else
  echo "→ docs/dev_journal.md already exists"
fi

if [ ! -f docs/product_insights.md ]; then
  cat > docs/product_insights.md << 'EOF'
# Product Insight Journal
> Chronological log of user pain points, UX friction, product hypotheses,
> positioning insights, roadmap trade-offs, experiments, and product decisions.

---
EOF
  echo "✓ docs/product_insights.md"
else
  echo "→ docs/product_insights.md already exists"
fi

echo ""
echo "Journal system ready at $ROOT/docs/"
echo "Next: install hooks and adapters — see journaling/README.md"
